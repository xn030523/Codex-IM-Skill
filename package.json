{
  "name": "codex-skill",
  "version": "0.1.0",
  "description": "Codex skill: bridge Telegram to Claude Code or Codex sessions",
  "keywords": [
    "claude-code",
    "codex",
    "telegram",
    "skill",
    "bridge"
  ],
  "files": [
    "dist",
    "scripts",
    "src",
    "SKILL.md",
    "README.md",
    "README_CN.md",
    "LICENSE",
    "SECURITY.md",
    "config.env.example",
    "tsconfig.json"
  ],
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "tg:chat-id": "node scripts/telegram-cli.js chat-id",
    "tg:setup": "node scripts/telegram-cli.js setup",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/main.ts",
    "test": "CTI_HOME=$(mktemp -d) node --test --import tsx --test-timeout=15000 src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.62",
    "claude-to-im": "github:op7418/claude-to-im"
  },
  "optionalDependencies": {
    "@openai/codex-sdk": "^0.110.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
